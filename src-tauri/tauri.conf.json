{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flip-clock",
  "identifier": "cn.smileyan.app",
  "version": "1.0.7",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "翻转时钟",
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/linux-16.png",
      "icons/linux-22.png",
      "icons/linux-24.png",
      "icons/linux-32.png",
      "icons/linux-48.png",
      "icons/linux-64.png",
      "icons/linux-128.png",
      "icons/linux-256.png",
      "icons/linux-512.png"
    ],
    "resources": [
      "icons/icon.svg"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "files": {
          "/usr/share/icons/hicolor/scalable/apps/cn.smileyan.app.svg": "icons/icon.svg"
        }
      },
      "appimage": {
        "files": {
          "/usr/share/icons/hicolor/scalable/apps/cn.smileyan.app.svg": "icons/icon.svg"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/smile-yan/flip-clock/releases/latest/download/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5NzMwODNBREIwQUU4RjYKUldUMjZBcmJPZ2h6K1NmZVg4cVFoRE9ZZzc2QjFvNlVvS1hjWjlydnZBSVljSGpNczZQM1Q5a24K"
    }
  }
}